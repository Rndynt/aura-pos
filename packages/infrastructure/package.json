{
  "name": "@pos/infrastructure",
  "version": "1.0.0",
  "description": "Infrastructure layer for multi-variant POS system",
  "type": "module",
  "main": "index.ts",
  "types": "index.ts",
  "exports": {
    ".": "./index.ts",
    "./database": "./database.ts",
    "./repositories": "./repositories/index.ts",
    "./repositories/*": "./repositories/*.ts",
    "./repositories/catalog/*": "./repositories/catalog/*.ts",
    "./repositories/orders/*": "./repositories/orders/*.ts",
    "./repositories/seating/*": "./repositories/seating/*.ts",
    "./repositories/tenants/*": "./repositories/tenants/*.ts",
    "./seeders": "./seeders/index.ts",
    "./seeders/*": "./seeders/*.ts",
    "./repositories/inventory": "./repositories/inventory/index.ts",
    "./repositories/inventory/*": "./repositories/inventory/*.ts",
    "./unit-of-work": "./unit-of-work/index.ts",
    "./unit-of-work/*": "./unit-of-work/*.ts"
  },
  "scripts": {
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "infrastructure",
    "repositories",
    "pos"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@pos/domain": "workspace:*",
    "@pos/application": "workspace:*"
  }
}
