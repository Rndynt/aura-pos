{
  "name": "@pos/domain",
  "version": "1.0.0",
  "description": "Domain models for multi-variant POS system",
  "type": "module",
  "main": "index.ts",
  "types": "index.ts",
  "exports": {
    ".": "./index.ts",
    "./catalog": "./catalog/index.ts",
    "./catalog/*": "./catalog/*.ts",
    "./orders": "./orders/index.ts",
    "./orders/*": "./orders/*.ts",
    "./pricing": "./pricing/index.ts",
    "./pricing/*": "./pricing/*.ts",
    "./tenants": "./tenants/index.ts",
    "./tenants/*": "./tenants/*.ts"
  },
  "scripts": {
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "domain",
    "ddd",
    "pos"
  ],
