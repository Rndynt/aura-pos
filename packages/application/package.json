{
  "name": "@pos/application",
  "version": "1.0.0",
  "description": "Application layer use cases for multi-variant POS system",
  "type": "module",
  "main": "index.ts",
  "types": "index.ts",
  "exports": {
    ".": "./index.ts",
    "./catalog": "./catalog/index.ts",
    "./catalog/*": "./catalog/*.ts",
    "./orders": "./orders/index.ts",
    "./orders/*": "./orders/*.ts",
    "./seating/*": "./seating/*.ts",
    "./tenants": "./tenants/index.ts",
    "./tenants/*": "./tenants/*.ts",
    "./sync/*": "./sync/*.ts",
    "./inventory": "./inventory/index.ts",
    "./inventory/*": "./inventory/*.ts",
    "./shared/ports": "./shared/ports/index.ts",
    "./shared/ports/*": "./shared/ports/*.ts",
    "./orders/ports": "./orders/ports/index.ts",
    "./orders/ports/*": "./orders/ports/*.ts",
    "./catalog/ports": "./catalog/ports/index.ts",
    "./catalog/ports/*": "./catalog/ports/*.ts",
    "./tenants/ports": "./tenants/ports/index.ts",
    "./tenants/ports/*": "./tenants/ports/*.ts",
    "./inventory/ports": "./inventory/ports/index.ts",
    "./inventory/ports/*": "./inventory/ports/*.ts",
    "./entitlements": "./entitlements/index.ts",
    "./entitlements/*": "./entitlements/*.ts",
    "./business-flows": "./business-flows/index.ts",
    "./business-flows/*": "./business-flows/*.ts"
  },
  "scripts": {
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --tsconfig tsconfig.json orders/__tests__/orderLifecycleDtoMapper.test.ts && tsx --tsconfig tsconfig.json orders/__tests__/UpdateOrder.lifecycleLocks.test.ts && tsx --tsconfig tsconfig.json business-flows/__tests__/resolveBusinessProfile.test.ts && tsx --tsconfig tsconfig.json business-flows/__tests__/orderActionPolicy.test.ts"
  },
  "keywords": [
    "application",
    "use-cases",
    "pos"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@pos/domain": "workspace:*"
  }
}
