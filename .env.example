# AuraPoS local development environment template.
# Copy to `.env` for local development only:
#   cp .env.example .env
#
# Do not put real production/staging secrets in this file.
# For staging and production requirements, see docs/ENVIRONMENT.md.

# Runtime
NODE_ENV=development
PORT=5000

# Database (local development placeholder)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aurapos_dev

# Optional Redis for local distributed cache/pubsub testing.
# Leave empty/commented for simple one-process local development.
# REDIS_URL=redis://localhost:6379/0

# Authentication (local placeholder; replace in your uncommitted .env)
BETTER_AUTH_SECRET=local-dev-secret-change-me-at-least-32-chars
BETTER_AUTH_URL=http://localhost:5000

# Local browser origins. See docs/ENVIRONMENT.md for production origin policy.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
TRUST_PROXY=false
LOG_LEVEL=debug
RATE_LIMIT_STORE=memory

# Reserved local placeholders for terminal/device and entitlement signing features.
# These local placeholders are at least 32 characters but are not production-safe.
# Generate unique secrets per environment before enabling these features outside dev.
TERMINAL_TOKEN_SECRET=local-terminal-token-secret-change-me-32chars-min
ENTITLEMENT_SNAPSHOT_SECRET=local-entitlement-snapshot-secret-change-me-32chars-min

# POS terminal frontend (Vite/browser-visible; never store secrets in VITE_* values)
VITE_API_URL=http://localhost:5000
VITE_APP_ENV=development
# VITE_BASE_DOMAIN=localhost
